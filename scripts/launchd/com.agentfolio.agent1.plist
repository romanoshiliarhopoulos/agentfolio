<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentfolio.agent1</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/romanos/agentfolio/scripts/run_agent1.sh</string>
    </array>

    <!-- Sunday 02:00 — opens the first 5-hour window for the week -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key><integer>0</integer>
        <key>Hour</key><integer>2</integer>
        <key>Minute</key><integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/romanos/agentfolio/data/logs/launchd_weekly.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/romanos/agentfolio/data/logs/launchd_weekly_err.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
